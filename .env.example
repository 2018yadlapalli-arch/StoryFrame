ANTHROPIC_API_KEY=sk-ant-your-key-here
REPLICATE_API_TOKEN=r8_your-token-here
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Image generation model (choose one)
# REPLICATE_MODEL=black-forest-labs/flux-schnell
# REPLICATE_MODEL=stability-ai/sdxl
REPLICATE_MODEL=black-forest-labs/flux-schnell

# Number of frames to generate (more = longer video, more API calls)
FRAME_COUNT=20

# Target video duration in seconds (300 = 5 min, 600 = 10 min)
VIDEO_DURATION_SECONDS=600

# Data directory (absolute path)
DATA_DIR=/home/nvidia/AI Video/data
